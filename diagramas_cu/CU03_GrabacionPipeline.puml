@startuml
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam defaultFontSize 14
title CU-07 a CU-15: Grabación y Pipeline de Análisis

left to right direction

actor "Médico" as Medico
actor "Sistema (n8n + ML)" as Sistema

rectangle "Grabación y Pipeline de Análisis" {
  usecase "CU-07: Capturar Audio\ndel Paciente" as CU07
  usecase "CU-08: Validar Calidad\nde Audio" as CU08
  usecase "CU-09: Almacenar Audio\nen MinIO" as CU09
  usecase "CU-10: Transcribir Voz\n(Whisper)" as CU10
  usecase "CU-11: Extraer Features\nAcústicas" as CU11
  usecase "CU-12: Analizar Rasgos\nLingüísticos" as CU12
  usecase "CU-13: Integrar Datos\nClínicos" as CU13
  usecase "CU-14: Predecir Riesgo\n(XGBoost)" as CU14
  usecase "CU-15: Generar Informe\nde Sesión" as CU15
}

Medico --> CU07
Sistema --> CU08
Sistema --> CU09
Sistema --> CU10
Sistema --> CU11
Sistema --> CU12
Sistema --> CU13
Sistema --> CU14
Sistema --> CU15

CU07 ..> CU08 : <<include>>
CU08 ..> CU09 : <<include>>
CU09 ..> CU10 : <<include>>
CU09 ..> CU11 : <<include>>
CU10 ..> CU12 : <<include>>
CU11 ..> CU14 : <<include>>
CU12 ..> CU14 : <<include>>
CU13 ..> CU14 : <<include>>
CU14 ..> CU15 : <<include>>
@enduml