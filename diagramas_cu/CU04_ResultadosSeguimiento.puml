@startuml
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam defaultFontSize 14
title CU-16 a CU-18: Resultados y Seguimiento

left to right direction

actor "Médico" as Medico
actor "Sistema" as Sys

rectangle "Resultados y Seguimiento" {
  usecase "CU-16: Visualizar Resultados\nde Análisis" as CU16
  usecase "CU-17: Gestionar Alertas\nAutomáticas" as CU17
  usecase "CU-18: Seguimiento\nLongitudinal" as CU18
}

Medico --> CU16
Medico --> CU18
Medico --> CU17

Sys --> CU17 : <<dispara alerta>>
CU16 ..> CU18 : <<include>>
@enduml