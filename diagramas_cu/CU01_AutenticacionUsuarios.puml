@startuml
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam defaultFontSize 14
title CU-01 a CU-03: Autenticación y Gestión de Usuarios

left to right direction

actor "Administrador" as Admin
actor "Médico" as Medico
actor "Auditor" as Auditor
actor "Sistema" as Sys

rectangle "Módulo de Autenticación y Usuarios" {
  usecase "CU-01: Iniciar Sesión\n(Login JWT)" as Login
  usecase "CU-02: Gestionar Usuarios\n(CRUD + Roles)" as CU02
  usecase "CU-03: Controlar Acceso\npor Roles" as CU03
}

Admin --> Login
Admin --> CU02
Medico --> Login
Auditor --> Login

Login ..> CU03 : <<include>>
CU02 ..> CU03 : <<include>>
@enduml