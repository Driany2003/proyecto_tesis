# Copiar a .env o definir en el servidor (producción, perfil spring.profiles.active=prod)
# No subir archivo .env con valores reales al repositorio.

DB_HOST=5.78.157.191
DB_PORT=5432
DB_NAME=tesis_parkinson
DB_USER=giomar
DB_PASSWORD=<tu-contraseña>

# JWT (recomendado en prod)
JWT_SECRET=<clave-secreta-min-32-caracteres>
JWT_EXPIRATION_MS=86400000

# MinIO (grabaciones de voz)
APP_MINIO_ENDPOINT=http://your-minio:9000
APP_MINIO_ACCESS_KEY=
APP_MINIO_SECRET_KEY=
APP_MINIO_BUCKET=parkinsonvoicesdata

# n8n — URL completa del webhook (vacío = no dispara pipeline)
APP_N8N_WEBHOOK_URL=http://5.78.157.191:5678/webhook/parkinson/analyze
