# ============================================================
# Backend Parkinson — Variables de entorno
# ============================================================
# Copia este archivo como .env y ajusta los valores reales.
# NUNCA subas .env al repositorio (está en .gitignore).

# --- PostgreSQL ---
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/tesis_parkinson
SPRING_DATASOURCE_USERNAME=parkinson_user
SPRING_DATASOURCE_PASSWORD=cambiame
SPRING_DATASOURCE_POOL_MAX=10
SPRING_DATASOURCE_POOL_MIN=2

# --- JWT ---
JWT_SECRET=genera-un-secreto-256-bits-seguro-aqui
JWT_EXPIRATION_MS=86400000

# --- MinIO ---
MINIO_ENDPOINT=http://localhost:9000
MINIO_PUBLIC_ENDPOINT=https://minio.tu-dominio.com
MINIO_ACCESS_KEY=minio_access_key
MINIO_SECRET_KEY=minio_secret_key

# --- n8n ---
N8N_WEBHOOK_URL=http://localhost:5678/webhook/parkinson/analyze
WEBHOOK_RECORDING_SECRET=genera-un-secreto-largo-para-el-webhook

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
