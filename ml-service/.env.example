# === ML Service Config ===
ML_DEBUG=true
ML_WHISPER_MODEL_SIZE=base
ML_AUDIO_TMP_DIR=/tmp/parkinson_audio
ML_MODEL_PATH=./models/parkinson_model.joblib

# Validación de audio
ML_AUDIO_MIN_DURATION_SEC=1.0
ML_AUDIO_MAX_DURATION_SEC=300.0
ML_AUDIO_MIN_SAMPLE_RATE=8000
ML_AUDIO_MAX_FILE_SIZE_MB=50.0

# CORS (separar múltiples con coma)
ML_CORS_ORIGINS=["http://localhost:5173","http://localhost:8080","http://localhost:5678"]
